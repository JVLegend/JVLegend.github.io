---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';

import heroImage from '~/assets/images/jv-perfil-2025.jpeg';
import techBack from '~/assets/images/tech_back.jpg';
import coliriosBack from '~/assets/images/colirios_back_1.jpg';

const metadata = {
  title: 'João Victor Pacheco Dias · Arquiteto de IA Médica · Doutorando FMUSP',
  ignoreTitleTemplate: true,
};

const expertise = [
  {
    cluster: 'Engenharia de IA',
    items: [
      { icon: 'tabler:eye', title: 'Computer Vision', description: 'Sistemas de visão computacional para aplicações médicas e industriais.' },
      { icon: 'tabler:message-2', title: 'Natural Language Processing', description: 'Processamento de linguagem natural e análise de texto.' },
      { icon: 'tabler:brain', title: 'Machine Learning', description: 'Algoritmos de ML para análise preditiva e automação inteligente.' },
    ],
  },
  {
    cluster: 'IA para Saúde',
    items: [
      { icon: 'tabler:heart', title: 'Healthcare AI', description: 'Aplicações de IA para medicina, especialmente oftalmologia.' },
      { icon: 'tabler:coins', title: 'Fintech para saúde', description: 'Soluções financeiras especializadas para profissionais de saúde.' },
    ],
  },
  {
    cluster: 'Liderança e Método',
    items: [
      { icon: 'tabler:users', title: 'Liderança técnica', description: 'Criação e liderança de equipes de Data Science em diversos setores.' },
      { icon: 'tabler:book', title: 'Organização científica', description: 'Sistema P.A.R.A. adaptado para escrita e pesquisa científica.' },
    ],
  },
];

const stats = [
  { amount: '2012', label: 'Em dados e IA desde' },
  { amount: '7', label: 'Empresas de saúde digital' },
  { amount: 'FMUSP', label: 'Pesquisa clínica' },
  { amount: 'CTO', label: 'Lyen e Spero Science' },
];
---

<Layout metadata={metadata}>
  <!-- Hero: split assimétrico, texto à esquerda, retrato à direita -->
  <section class="relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-12 md:pt-20 pb-16 md:pb-24">
      <div class="grid gap-10 lg:grid-cols-12 lg:items-center motion-safe:animate-fade">
        <div class="lg:col-span-7">
          <p class="text-sm uppercase tracking-[0.18em] font-semibold text-primary mb-5">
            Arquiteto de IA Médica · Doutorando FMUSP
          </p>
          <h1 class="font-heading font-bold tracking-tighter leading-none text-5xl md:text-6xl xl:text-7xl text-gray-900 dark:text-slate-100">
            João Victor Dias
          </h1>
          <p class="mt-6 text-lg md:text-xl text-gray-600 dark:text-slate-400 leading-relaxed max-w-[52ch]">
            Pesquisa clínica, produtos de saúde digital em produção e educação médica. Construindo IA que funciona na prática clínica desde 2012.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-3 max-w-xs sm:max-w-none">
            <a class="btn-primary" href="/cv">
              <Icon name="tabler:user" class="w-5 h-5 mr-2 -ml-1" />
              Ver CV
            </a>
            <a class="btn-secondary" href="/contact">Contato</a>
          </div>
        </div>
        <div class="lg:col-span-5">
          <div class="relative max-w-sm mx-auto lg:max-w-none lg:ml-auto">
            <div class="absolute -inset-3 rounded-2xl bg-primary/10 dark:bg-primary/20 rotate-2" aria-hidden="true"></div>
            <Image
              src={heroImage}
              alt="João Victor Dias"
              width={640}
              height={960}
              loading="eager"
              class="relative rounded-2xl object-cover w-full aspect-[3/4] shadow-lg"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sobre: âncora editorial à esquerda, pilares à direita -->
  <section class="border-t border-gray-200 dark:border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <h2 class="font-heading font-bold tracking-tight text-3xl md:text-4xl text-gray-900 dark:text-slate-100">
            Pesquisa, produto e educação. Um foco: saúde.
          </h2>
          <p class="mt-6 text-gray-600 dark:text-slate-400 leading-relaxed max-w-[65ch]">
            Projeto e mantenho a espinha dorsal tecnológica de um ecossistema de healthtech: a mesma IA, as mesmas
            automações e integrações médicas potencializando as empresas do grupo. Combino pesquisa clínica no
            HC-FMUSP com produtos em produção.
          </p>
        </div>
        <div class="lg:col-span-7 space-y-10 lg:pl-8 lg:border-l border-gray-200 dark:border-slate-800">
          <div>
            <h3 class="font-heading font-semibold text-xl text-gray-900 dark:text-slate-100">Uma arquitetura, múltiplos mercados</h3>
            <p class="mt-2 text-gray-600 dark:text-slate-400 leading-relaxed">
              Infraestrutura de IA para um ecossistema de empresas de saúde digital: cada uma com CEO focado em
              mercado, enquanto eu garanto que a tecnologia seja de classe mundial.
            </p>
          </div>
          <div>
            <h3 class="font-heading font-semibold text-xl text-gray-900 dark:text-slate-100">Pesquisa com impacto real na FMUSP</h3>
            <p class="mt-2 text-gray-600 dark:text-slate-400 leading-relaxed">
              Doutorado em andamento em Ciências Médicas Oftalmológicas. Pipeline de ML para análise de piscadas e
              projeto NeuroGenetics (retina × APOE, p&lt;0,05). O laboratório alimenta os produtos.
            </p>
          </div>
          <div>
            <h3 class="font-heading font-semibold text-xl text-gray-900 dark:text-slate-100">Linhas de pesquisa em expansão</h3>
            <p class="mt-2 text-gray-600 dark:text-slate-400 leading-relaxed">
              Oculômica e prevenção de AVC (INCT-PreAVC), resistência antimicrobiana com IA e segmentação de retina
              em OCT (desafio MICCAI 2026).
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Expertise: clusters agrupados, sem cards -->
  <section id="expertise" class="bg-blue-50/50 dark:bg-slate-900/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <h2 class="font-heading font-bold tracking-tight text-3xl md:text-4xl text-gray-900 dark:text-slate-100">
        Áreas de especialização
      </h2>
      <p class="mt-4 text-gray-600 dark:text-slate-400 max-w-[65ch]">
        Mais de uma década construindo soluções de IA que impactam diversos setores.
      </p>
      <div class="mt-12 grid gap-10 md:grid-cols-3">
        {
          expertise.map(({ cluster, items }) => (
            <div class="border-t-2 border-primary/70 pt-6">
              <h3 class="font-heading font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-slate-500">{cluster}</h3>
              <ul class="mt-6 space-y-6">
                {items.map(({ icon, title, description }) => (
                  <li class="flex gap-3">
                    <Icon name={icon} class="w-6 h-6 shrink-0 text-primary mt-0.5" />
                    <div>
                      <p class="font-semibold text-gray-900 dark:text-slate-100">{title}</p>
                      <p class="mt-1 text-sm text-gray-600 dark:text-slate-400 leading-relaxed">{description}</p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Ecossistema: bento grid com ritmo -->
  <section>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <h2 class="font-heading font-bold tracking-tight text-3xl md:text-4xl text-gray-900 dark:text-slate-100">
        Ecossistema de saúde digital
      </h2>
      <p class="mt-4 text-gray-600 dark:text-slate-400 max-w-[65ch]">
        Verticais especializadas, cada uma com CEO dedicado ao mercado. O que é construído para uma empresa
        beneficia todas as outras.
      </p>

      <div class="mt-12 grid gap-4 md:grid-cols-6">
        <div class="relative overflow-hidden rounded-2xl md:col-span-4 min-h-[16rem]">
          <Image src={techBack} alt="Bastidores de tecnologia do grupo" class="absolute inset-0 w-full h-full object-cover" width={1200} height={640} />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/60 to-slate-950/30" aria-hidden="true"></div>
          <div class="relative p-6 md:p-8 flex flex-col justify-end min-h-[16rem]">
            <h3 class="font-heading font-bold text-2xl text-white">IA para Médicos</h3>
            <p class="text-sm text-slate-300 mt-1">CEO: Karine Dias</p>
            <p class="mt-3 text-slate-200 leading-relaxed max-w-[60ch]">
              Motor de receita do grupo: NeuroApp, NeuroForm, NeuroGenetics e ecossistema educacional com cursos e
              assistentes de IA para escrita científica médica.
            </p>
          </div>
        </div>

        <div class="rounded-2xl md:col-span-2 p-6 md:p-8 bg-primary text-white flex flex-col justify-end">
          <h3 class="font-heading font-bold text-2xl">WingsAI</h3>
          <p class="text-sm text-blue-100 mt-1">CEO: Eduardo Silva</p>
          <p class="mt-3 text-blue-50 leading-relaxed">
            Deeptech de P&amp;D aplicado à saúde: AEO Advogados, Blinktracking, Setor IA FMUSP e Podcast WingsAI.
          </p>
        </div>

        <div class="rounded-2xl md:col-span-2 p-6 md:p-8 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-800">
          <h3 class="font-heading font-bold text-xl text-gray-900 dark:text-slate-100">GeekVision</h3>
          <p class="text-sm text-gray-500 dark:text-slate-500 mt-1">CEO: Dr. Pedro Carricondo</p>
          <p class="mt-3 text-gray-600 dark:text-slate-400 leading-relaxed">
            Hub de produtos digitais para IA médica: AEO Doctors e BioGeek, análise estatística para pesquisadores.
          </p>
        </div>

        <div class="rounded-2xl md:col-span-2 p-6 md:p-8 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-800">
          <h3 class="font-heading font-bold text-xl text-gray-900 dark:text-slate-100">ConnectAI / Repport AI</h3>
          <p class="text-sm text-gray-500 dark:text-slate-500 mt-1">CEO: Marcelo</p>
          <p class="mt-3 text-gray-600 dark:text-slate-400 leading-relaxed">
            Sales intelligence médica e automação de relatórios com IA.
          </p>
        </div>

        <div class="relative overflow-hidden rounded-2xl md:col-span-2 min-h-[14rem]">
          <Image src={coliriosBack} alt="Colírios em bancada clínica" class="absolute inset-0 w-full h-full object-cover" width={640} height={480} />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/60 to-slate-950/30" aria-hidden="true"></div>
          <div class="relative p-6 md:p-8 flex flex-col justify-end min-h-[14rem]">
            <h3 class="font-heading font-bold text-xl text-white">PacienteAlerta</h3>
            <p class="mt-3 text-slate-200 leading-relaxed">
              Lembretes e adesão ao tratamento via WhatsApp. Em validação clínica.
            </p>
          </div>
        </div>

        <div class="rounded-2xl md:col-span-3 p-6 md:p-8 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-800">
          <h3 class="font-heading font-bold text-xl text-gray-900 dark:text-slate-100">Lyen</h3>
          <p class="text-sm text-gray-500 dark:text-slate-500 mt-1">Sócio e CTO desde 2026</p>
          <p class="mt-3 text-gray-600 dark:text-slate-400 leading-relaxed">
            Plataforma de vagas médicas que conecta médicos a oportunidades de plantão e carreira.
          </p>
        </div>

        <div class="rounded-2xl md:col-span-3 p-6 md:p-8 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-800">
          <h3 class="font-heading font-bold text-xl text-gray-900 dark:text-slate-100">Spero Science</h3>
          <p class="text-sm text-gray-500 dark:text-slate-500 mt-1">CTO desde 2026</p>
          <p class="mt-3 text-gray-600 dark:text-slate-400 leading-relaxed">
            Plataforma de IA aplicada da Spero Science, em produção na infraestrutura própria da empresa.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Números: strip sem cards -->
  <section class="border-t border-gray-200 dark:border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-16">
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-10">
        {
          stats.map(({ amount, label }) => (
            <div>
              <dd class="font-heading font-bold tracking-tight text-4xl md:text-5xl text-primary">{amount}</dd>
              <dt class="mt-2 text-sm text-gray-600 dark:text-slate-400">{label}</dt>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-blue-50/50 dark:bg-slate-900/40 border-t border-gray-200 dark:border-slate-800">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 md:py-24 text-center">
      <h2 class="font-heading font-bold tracking-tight text-3xl md:text-4xl text-gray-900 dark:text-slate-100">
        Construindo IA médica que gera impacto real?
      </h2>
      <p class="mt-4 text-gray-600 dark:text-slate-400">
        Aberto a conversas sobre parcerias tecnológicas, grants internacionais e projetos de saúde digital.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3 max-w-xs sm:max-w-none mx-auto">
        <a class="btn-primary" href="/cv">
          <Icon name="tabler:file-text" class="w-5 h-5 mr-2 -ml-1" />
          Ver CV
        </a>
        <a class="btn-secondary" href="/contact">
          <Icon name="tabler:mail" class="w-5 h-5 mr-2 -ml-1" />
          Contato
        </a>
      </div>
    </div>
  </section>
</Layout>
