---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Stats from '~/components/widgets/Stats.astro';

import heroImage from '~/assets/images/jv-perfil-2025.jpeg';
import techBack from '~/assets/images/tech_back.jpg';
import coliriosBack from '~/assets/images/colirios_back_1.jpg';

const metadata = {
  title: 'João Victor Pacheco Dias — Arquiteto de IA Médica & Doutorando FMUSP',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Ver CV',
        href: '/cv',
        icon: 'tabler:user',
      },
      { text: 'Contato', href: '/contact' },
    ]}
    image={{ src: heroImage, alt: 'João Victor Dias', width: 640, height: 960 }}
  >
    <Fragment slot="title">
      <span class="font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500 dark:from-blue-400 dark:to-cyan-300" style="font-family: 'Poppins', sans-serif;">João Victor Dias</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">Arquiteto de IA Médica • Deeptech • Doutorando FMUSP</span> — 15 anos construindo IA que funciona na prática clínica.
      </span>
      <span class="block mb-1 sm:hidden font-bold text-blue-600">Arquiteto de IA Médica</span>
      Uma plataforma tecnológica, cinco verticais de impacto em saúde digital. Doutorando em Ciências Médicas Oftalmológicas na FMUSP.
    </Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    tagline="Sobre"
    title="Arquiteto de IA Médica"
    items={[
      {
        title: 'Uma arquitetura, múltiplos mercados',
        description:
          'Desenvolvo a infraestrutura tecnológica de IA para um ecossistema de empresas de saúde digital — cada uma com CEO focado em mercado, enquanto eu garanto que a tecnologia seja de classe mundial.',
      },
      {
        title: 'Pesquisa com impacto real — FMUSP',
        description:
          'PhD em Ciências Médicas Oftalmológicas. Pipeline ML para análise de piscadas e projeto NeuroGenetics (retina × APOE, p<0,05). O laboratório alimenta os produtos.',
      },
      {
        title: 'Pipeline de Grants Internacional',
        description:
          'Grants ativos: PIPE FAPESP-PRODESP, Filecoin Foundation, Google.org AI for Science, Climate Change AI, FINEP 773.',
      },
    ]}
    image={{
      src: techBack,
      alt: 'João Victor trabalhando',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Uma plataforma. Cinco verticais. Um foco.</h3>
      João Victor Pacheco Dias projeta e mantém a espinha dorsal tecnológica de um ecossistema de healthtech — a mesma IA, as mesmas automações e integrações médicas potencializando cinco empresas ao mesmo tempo.
      Com 15 anos de experiência em IA, combina pesquisa clínica no HC-FMUSP com produtos em produção e captação de grants internacionais.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Features Widget *************** -->

  <Features
    id="expertise"
    tagline="Expertise"
    title="Áreas de Especialização"
    subtitle="Mais de uma década construindo soluções de IA que impactam diversos setores."
    items={[
      {
        title: 'Computer Vision',
        description:
          'Desenvolvimento de sistemas de visão computacional para aplicações médicas e industriais.',
        icon: 'tabler:eye',
      },
      {
        title: 'Natural Language Processing',
        description:
          'Soluções avançadas de processamento de linguagem natural e análise de texto.',
        icon: 'tabler:message-2',
      },
      {
        title: 'Machine Learning',
        description:
          'Implementação de algoritmos de ML para análise preditiva e automação inteligente.',
        icon: 'tabler:brain',
      },
      {
        title: 'Liderança Técnica',
        description:
          'Experiência na criação e liderança de equipes de Data Science em diversos setores.',
        icon: 'tabler:users',
      },
      {
        title: 'Healthcare AI',
        description:
          'Especialização em aplicações de IA para medicina, especialmente oftalmologia.',
        icon: 'tabler:heart',
      },
      {
        title: 'Organização Científica',
        description:
          'Aplicação do Sistema P.A.R.A. adaptado para escrita e pesquisa científica.',
        icon: 'tabler:book',
      },
      {
        title: 'Inovação Fintech',
        description:
          'Desenvolvimento de soluções financeiras especializadas para profissionais de saúde.',
        icon: 'tabler:coins',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    items={[
      {
        title: 'IA para Médicos (CEO: Karine Dias)',
        description: 'Motor de receita do grupo. Projetos ativos: NeuroApp, NeuroForm, NeuroGenetics, PacienteAlerta, HC-FMUSP. Ecossistema educacional com cursos e assistentes IA para escrita científica médica.',
      },
      {
        title: 'WingsAI (CEO: Eduardo Silva)',
        description: 'Deeptech focada em P&D e grants. AEO Advogados, Blinktracking PhD, Setor IA FMUSP, Podcast WingsAI. Pipeline de grants: PIPE FAPESP, Filecoin, Google.org, FINEP 773.',
      },
      {
        title: 'GeekVision (CEO: Dr. Pedro Carricondo)',
        description: 'Hub de produtos digitais para IA médica. AEO Doctors (CDO: Henrique; Medical Advisor: Dra. Maria Fernanda) e BioGeek — análise estatística para pesquisadores.',
      },
      {
        title: 'ConnectAI (CEO: Marcelo)',
        description: 'Nova empresa em formação focada em sales intelligence médica. PPTs Pré-Visita, scraper LinkedIn. Dev mobile: Raul.',
      },
      {
        title: 'PacienteAlerta (CEO: Dra. Ana Vega — a confirmar)',
        description: 'Sistema de lembretes e adesão ao tratamento via WhatsApp. Em validação clínica.',
      },
    ]}
    image={{
      src: coliriosBack,
      alt: 'Projetos e negócios',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Ecossistema de Saúde Digital</h3>
      Cinco verticais especializadas, cada uma com CEO dedicado ao mercado. A vantagem competitiva está na arquitetura compartilhada: o que é construído para uma empresa beneficia todas as outras — velocidade de startup, solidez de empresa madura.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Anos em IA', amount: '15+' },
      { title: 'Verticais de Saúde', amount: '5' },
      { title: 'Especialização', amount: 'Healthcare AI' },
      { title: 'Pesquisa Clínica', amount: 'FMUSP' },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Ver CV Completo',
        href: '/cv',
        icon: 'tabler:file-text',
      },
      {
        variant: 'secondary',
        text: 'Contato',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">
      Construindo IA médica<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"> que gera impacto real?</span>
    </Fragment>

    <Fragment slot="subtitle">
      Aberto a conversas sobre parcerias tecnológicas, grants internacionais
      <br class="hidden md:inline" />e projetos de saúde digital.
    </Fragment>
  </CallToAction>
</Layout>