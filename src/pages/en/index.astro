---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';

import heroImage from '~/assets/images/jv-perfil-2025.jpeg';
import techBack from '~/assets/images/tech_back.jpg';
import coliriosBack from '~/assets/images/colirios_back_1.jpg';

const metadata = {
  title: 'João Victor Pacheco Dias · Medical AI Architect · PhD Candidate at FMUSP',
  ignoreTitleTemplate: true,
};

const expertise = [
  {
    cluster: 'AI Engineering',
    items: [
      { icon: 'tabler:eye', title: 'Computer Vision', description: 'Computer vision systems for medical and industrial applications.' },
      { icon: 'tabler:message-2', title: 'Natural Language Processing', description: 'Natural language processing and text analysis.' },
      { icon: 'tabler:brain', title: 'Machine Learning', description: 'ML algorithms for predictive analytics and intelligent automation.' },
    ],
  },
  {
    cluster: 'AI for Healthcare',
    items: [
      { icon: 'tabler:heart', title: 'Healthcare AI', description: 'AI applications for medicine, with a focus on ophthalmology.' },
      { icon: 'tabler:coins', title: 'Fintech for healthcare', description: 'Specialized financial solutions for healthcare professionals.' },
    ],
  },
  {
    cluster: 'Leadership and Method',
    items: [
      { icon: 'tabler:users', title: 'Technical leadership', description: 'Building and leading Data Science teams across industries.' },
      { icon: 'tabler:book', title: 'Scientific organization', description: 'P.A.R.A. system adapted for scientific writing and research.' },
    ],
  },
];

const stats = [
  { amount: '2012', label: 'Working with data and AI since' },
  { amount: '7', label: 'Digital health companies' },
  { amount: 'FMUSP', label: 'Clinical research' },
  { amount: 'CTO', label: 'Lyen and Spero Science' },
];
---

<Layout metadata={metadata}>
  <!-- Hero: asymmetric split, text left, portrait right -->
  <section class="relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-12 md:pt-20 pb-16 md:pb-24">
      <div class="grid gap-10 lg:grid-cols-12 lg:items-center motion-safe:animate-fade">
        <div class="lg:col-span-7">
          <p class="text-sm uppercase tracking-[0.18em] font-semibold text-primary mb-5">
            Medical AI Architect · PhD Candidate at FMUSP
          </p>
          <h1 class="font-heading font-bold tracking-tighter leading-none text-5xl md:text-6xl xl:text-7xl text-gray-900 dark:text-slate-100">
            João Victor Dias
          </h1>
          <p class="mt-6 text-lg md:text-xl text-gray-600 dark:text-slate-400 leading-relaxed max-w-[52ch]">
            Clinical research, digital health products in production and medical education. Building AI that works in clinical practice since 2012.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-3 max-w-xs sm:max-w-none">
            <a class="btn-primary" href="/en/cv">
              <Icon name="tabler:user" class="w-5 h-5 mr-2 -ml-1" />
              View CV
            </a>
            <a class="btn-secondary" href="/en/contact">Contact</a>
          </div>
        </div>
        <div class="lg:col-span-5">
          <div class="relative max-w-sm mx-auto lg:max-w-none lg:ml-auto">
            <div class="absolute -inset-3 rounded-2xl bg-primary/10 dark:bg-primary/20 rotate-2" aria-hidden="true"></div>
            <Image
              src={heroImage}
              alt="João Victor Dias"
              width={640}
              height={960}
              loading="eager"
              class="relative rounded-2xl object-cover w-full aspect-[3/4] shadow-lg"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About: editorial anchor left, pillars right -->
  <section class="border-t border-gray-200 dark:border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <h2 class="font-heading font-bold tracking-tight text-3xl md:text-4xl text-gray-900 dark:text-slate-100">
            Research, product and education. One focus: healthcare.
          </h2>
          <p class="mt-6 text-gray-600 dark:text-slate-400 leading-relaxed max-w-[65ch]">
            I design and maintain the technological backbone of a healthtech ecosystem: the same AI, the same
            automations and medical integrations powering the group's companies. I combine clinical research at
            HC-FMUSP with products in production.
          </p>
        </div>
        <div class="lg:col-span-7 space-y-10 lg:pl-8 lg:border-l border-gray-200 dark:border-slate-800">
          <div>
            <h3 class="font-heading font-semibold text-xl text-gray-900 dark:text-slate-100">One architecture, multiple markets</h3>
            <p class="mt-2 text-gray-600 dark:text-slate-400 leading-relaxed">
              AI infrastructure for an ecosystem of digital health companies: each one with a CEO focused on its
              market, while I make sure the technology is world-class.
            </p>
          </div>
          <div>
            <h3 class="font-heading font-semibold text-xl text-gray-900 dark:text-slate-100">Research with real impact at FMUSP</h3>
            <p class="mt-2 text-gray-600 dark:text-slate-400 leading-relaxed">
              Ongoing PhD in Ophthalmological Medical Sciences. ML pipeline for blink analysis and the NeuroGenetics
              project (retina × APOE, p&lt;0.05). The lab feeds the products.
            </p>
          </div>
          <div>
            <h3 class="font-heading font-semibold text-xl text-gray-900 dark:text-slate-100">Expanding research lines</h3>
            <p class="mt-2 text-gray-600 dark:text-slate-400 leading-relaxed">
              Oculomics and stroke prevention (INCT-PreAVC), antimicrobial resistance with AI and retina segmentation
              in OCT (MICCAI 2026 challenge).
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Expertise: grouped clusters, no cards -->
  <section id="expertise" class="bg-blue-50/50 dark:bg-slate-900/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <h2 class="font-heading font-bold tracking-tight text-3xl md:text-4xl text-gray-900 dark:text-slate-100">
        Areas of expertise
      </h2>
      <p class="mt-4 text-gray-600 dark:text-slate-400 max-w-[65ch]">
        More than a decade building AI solutions with impact across industries.
      </p>
      <div class="mt-12 grid gap-10 md:grid-cols-3">
        {
          expertise.map(({ cluster, items }) => (
            <div class="border-t-2 border-primary/70 pt-6">
              <h3 class="font-heading font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-slate-500">{cluster}</h3>
              <ul class="mt-6 space-y-6">
                {items.map(({ icon, title, description }) => (
                  <li class="flex gap-3">
                    <Icon name={icon} class="w-6 h-6 shrink-0 text-primary mt-0.5" />
                    <div>
                      <p class="font-semibold text-gray-900 dark:text-slate-100">{title}</p>
                      <p class="mt-1 text-sm text-gray-600 dark:text-slate-400 leading-relaxed">{description}</p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Ecosystem: bento grid with rhythm -->
  <section>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <h2 class="font-heading font-bold tracking-tight text-3xl md:text-4xl text-gray-900 dark:text-slate-100">
        Digital health ecosystem
      </h2>
      <p class="mt-4 text-gray-600 dark:text-slate-400 max-w-[65ch]">
        Specialized verticals, each with a CEO dedicated to its market. What is built for one company benefits all
        the others.
      </p>

      <div class="mt-12 grid gap-4 md:grid-cols-6">
        <div class="relative overflow-hidden rounded-2xl md:col-span-4 min-h-[16rem]">
          <Image src={techBack} alt="Technology behind the group" class="absolute inset-0 w-full h-full object-cover" width={1200} height={640} />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/60 to-slate-950/30" aria-hidden="true"></div>
          <div class="relative p-6 md:p-8 flex flex-col justify-end min-h-[16rem]">
            <h3 class="font-heading font-bold text-2xl text-white">IA para Médicos</h3>
            <p class="text-sm text-slate-300 mt-1">CEO: Karine Dias</p>
            <p class="mt-3 text-slate-200 leading-relaxed max-w-[60ch]">
              The group's revenue engine: NeuroApp, NeuroForm, NeuroGenetics and an educational ecosystem with
              courses and AI assistants for medical scientific writing.
            </p>
          </div>
        </div>

        <div class="rounded-2xl md:col-span-2 p-6 md:p-8 bg-primary text-white flex flex-col justify-end">
          <h3 class="font-heading font-bold text-2xl">WingsAI</h3>
          <p class="text-sm text-blue-100 mt-1">CEO: Eduardo Silva</p>
          <p class="mt-3 text-blue-50 leading-relaxed">
            Deeptech focused on R&amp;D applied to healthcare: AEO Advogados, Blinktracking, FMUSP AI Sector and the
            WingsAI Podcast.
          </p>
        </div>

        <div class="rounded-2xl md:col-span-2 p-6 md:p-8 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-800">
          <h3 class="font-heading font-bold text-xl text-gray-900 dark:text-slate-100">GeekVision</h3>
          <p class="text-sm text-gray-500 dark:text-slate-500 mt-1">CEO: Dr. Pedro Carricondo</p>
          <p class="mt-3 text-gray-600 dark:text-slate-400 leading-relaxed">
            Digital product hub for medical AI: AEO Doctors and BioGeek, statistical analysis for researchers.
          </p>
        </div>

        <div class="rounded-2xl md:col-span-2 p-6 md:p-8 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-800">
          <h3 class="font-heading font-bold text-xl text-gray-900 dark:text-slate-100">ConnectAI / Repport AI</h3>
          <p class="text-sm text-gray-500 dark:text-slate-500 mt-1">CEO: Marcelo</p>
          <p class="mt-3 text-gray-600 dark:text-slate-400 leading-relaxed">
            Medical sales intelligence and AI-powered report automation.
          </p>
        </div>

        <div class="relative overflow-hidden rounded-2xl md:col-span-2 min-h-[14rem]">
          <Image src={coliriosBack} alt="Eye drops on a clinical bench" class="absolute inset-0 w-full h-full object-cover" width={640} height={480} />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/60 to-slate-950/30" aria-hidden="true"></div>
          <div class="relative p-6 md:p-8 flex flex-col justify-end min-h-[14rem]">
            <h3 class="font-heading font-bold text-xl text-white">PacienteAlerta</h3>
            <p class="mt-3 text-slate-200 leading-relaxed">
              Treatment reminders and adherence via WhatsApp. In clinical validation.
            </p>
          </div>
        </div>

        <div class="rounded-2xl md:col-span-3 p-6 md:p-8 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-800">
          <h3 class="font-heading font-bold text-xl text-gray-900 dark:text-slate-100">Lyen</h3>
          <p class="text-sm text-gray-500 dark:text-slate-500 mt-1">Partner and CTO since 2026</p>
          <p class="mt-3 text-gray-600 dark:text-slate-400 leading-relaxed">
            Medical jobs platform connecting physicians to shift and career opportunities.
          </p>
        </div>

        <div class="rounded-2xl md:col-span-3 p-6 md:p-8 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-800">
          <h3 class="font-heading font-bold text-xl text-gray-900 dark:text-slate-100">Spero Science</h3>
          <p class="text-sm text-gray-500 dark:text-slate-500 mt-1">CTO since 2026</p>
          <p class="mt-3 text-gray-600 dark:text-slate-400 leading-relaxed">
            Spero Science's applied AI platform, in production on the company's own infrastructure.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Numbers: strip, no cards -->
  <section class="border-t border-gray-200 dark:border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-16">
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-10">
        {
          stats.map(({ amount, label }) => (
            <div>
              <dd class="font-heading font-bold tracking-tight text-4xl md:text-5xl text-primary">{amount}</dd>
              <dt class="mt-2 text-sm text-gray-600 dark:text-slate-400">{label}</dt>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-blue-50/50 dark:bg-slate-900/40 border-t border-gray-200 dark:border-slate-800">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 md:py-24 text-center">
      <h2 class="font-heading font-bold tracking-tight text-3xl md:text-4xl text-gray-900 dark:text-slate-100">
        Building medical AI with real impact?
      </h2>
      <p class="mt-4 text-gray-600 dark:text-slate-400">
        Open to conversations about technology partnerships, international grants and digital health projects.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3 max-w-xs sm:max-w-none mx-auto">
        <a class="btn-primary" href="/en/cv">
          <Icon name="tabler:file-text" class="w-5 h-5 mr-2 -ml-1" />
          View CV
        </a>
        <a class="btn-secondary" href="/en/contact">
          <Icon name="tabler:mail" class="w-5 h-5 mr-2 -ml-1" />
          Contact
        </a>
      </div>
    </div>
  </section>
</Layout>
